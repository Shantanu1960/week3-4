import java.util.Scanner;

public class Level1 {
    private static Scanner scan = new Scanner(System.in);

    public static void divisibleBy5() {
        System.out.print(" number: ");
        int n = scan.nextInt();
        String result = (n % 5 == 0) ? "" : "not ";
        System.out.println(" Is the number " + n + " divisible by 5? " + result);
    }

    public static void firstSmallest() {
        System.out.print(" number1: ");
        int a = scan.nextInt();
        System.out.print(" number2: ");
        int b = scan.nextInt();
        System.out.print(" number3: ");
        int c = scan.nextInt();
        boolean isSmallest = a < b && a < c;
        System.out.println(" Is the first number the smallest? " + isSmallest);
    }

    public static void largestOfThree() {
        System.out.print(" number1: ");
        int a = scan.nextInt();
        System.out.print(" number2: ");
        int b = scan.nextInt();
        System.out.print(" number3: ");
        int c = scan.nextInt();
        System.out.println(" Is the first number the largest? " + (a > b && a > c));
        System.out.println("Is the second number the largest? " + (b > a && b > c));
        System.out.println("Is the third number the largest? " + (c > a && c > b));
    }

    public static void sumNatural() {
        System.out.print(" number: ");
        int n = scan.nextInt();
        if (n >= 0) {
            int s = n * (n + 1) / 2;
            System.out.println("  The sum of " + n + " natural numbers is " + s);
        } else {
            System.out.println("  The number " + n + " is not a natural number");
        }
    }

    public static void canVote() {
        System.out.print(" age: ");
        int age = scan.nextInt();
        if (age >= 18) {
            System.out.println(" The person's age is " + age + " and can vote.");
        } else {
            System.out.println(" The person's age is " + age + " and cannot vote.");
        }
    }

    public static void signCheck() {
        System.out.print("Enter an integer: ");
        int num = scan.nextInt();
        if (num > 0) {
            System.out.println("positive");
        } else if (num < 0) {
            System.out.println("negative");
        } else {
            System.out.println("zero");
        }
    }

    public static void springSeason() {
        System.out.print("Enter month as integer: ");
        int month = scan.nextInt();
        System.out.print("Enter day as integer: ");
        int day = scan.nextInt();
        boolean isSpring = false;
        if (month == 3 && day >= 20) {
            isSpring = true;
        } else if (month == 4 || month == 5) {
            isSpring = true;
        } else if (month == 6 && day <= 20) {
            isSpring = true;
        }
        System.out.println(isSpring ? "Its a Spring Season" : "Not a Spring Season");
    }

    public static void countdownWhile() {
        System.out.print("Enter countdown start value: ");
        int n = scan.nextInt();
        while (n >= 1) {
            System.out.println(n);
            n--;
        }
    }

    public static void countdownFor() {
        System.out.print("Enter countdown start value: ");
        int start = scan.nextInt();
        for (int i = start; i >= 1; i--) {
            System.out.println(i);
        }
    }

    public static void sumUntilZero() {
        double total = 0.0;
        while (true) {
            System.out.print("Enter a number (0 to quit): ");
            double x = scan.nextDouble();
            if (x == 0) break;
            total += x;
        }
        System.out.println("Total = " + total);
    }

    public static void sumUntilNonPos() {
        double total = 0.0;
        while (true) {
            System.out.print("Enter a number (<=0 to quit): ");
            double x = scan.nextDouble();
            if (x <= 0) break;
            total += x;
        }
        System.out.println("Total = " + total);
    }

    public static void compareNaturalSum() {
        System.out.print("Enter a natural number: ");
        int n = scan.nextInt();
        if (n < 0) {
            System.out.println(n + " is not a natural number");
            return;
        }
        int formula = n * (n + 1) / 2;
        int acc = 0;
        int i = 1;
        while (i <= n) {
            acc += i;
            i++;
        }
        System.out.println("formula = " + formula + ", while loop = " + acc);
        System.out.println(formula == acc ? "Results match" : "Mismatch");
    }

    public static void compareNaturalSumFor() {
        System.out.print("Enter a natural number: ");
        int n = scan.nextInt();
        if (n < 0) {
            System.out.println(n + " is not a natural number");
            return;
        }
        int formula = n * (n + 1) / 2;
        int acc = 0;
        for (int i = 1; i <= n; i++) {
            acc += i;
        }
        System.out.println("formula = " + formula + ", for loop = " + acc);
        System.out.println(formula == acc ? "Results match" : "Mismatch");
    }

    public static void factorialWhile() {
        System.out.print("Enter a positive integer: ");
        int n = scan.nextInt();
        if (n < 0) {
            System.out.println("Factorial is not defined for negative numbers");
            return;
        }
        int fact = 1;
        int i = 1;
        while (i <= n) {
            fact *= i;
            i++;
        }
        System.out.println("Factorial of " + n + " is " + fact);
    }

    public static void factorialFor() {
        System.out.print("Enter a positive integer: ");
        int n = scan.nextInt();
        if (n < 0) {
            System.out.println("Factorial is not defined for negative numbers");
            return;
        }
        int fact = 1;
        for (int i = 1; i <= n; i++) {
            fact *= i;
        }
        System.out.println("Factorial of " + n + " is " + fact);
    }

    public static void main(String[] args) {
        // call each program sequentially
        divisibleBy5();
        firstSmallest();
        largestOfThree();
        sumNatural();
        canVote();
        signCheck();
        springSeason();
        countdownWhile();
        countdownFor();
        sumUntilZero();
        sumUntilNonPos();
        compareNaturalSum();
        compareNaturalSumFor();
        factorialWhile();
        factorialFor();
    }
}